{# Example markup #}
<nav class="headerMenu">
  <ul class="nav-main">
    <li>
      {% include "partials/searchform.twig" %}
    </li>
    {# mainNav er globalt satt i inc/add_twig_nav.php #}
    {% for item in mainNav.items %}
    <li class="nav-main-item {{ item.classes|join(' ') }}">
      <a class="nav-main-link" href="{{ item.link }}">{{ item.title }}</a>
      {% if item.children %}
        <ul class="nav-drop">
          {% for child in item.children %}
            <li class="nav-drop-item">
              <a class="nav-main-link" href="{{ child.link }}">{{ child.title }}</a>
              {% if child.children %}
                <ul class="nav-drop">
                  {% for subchild in child.children %}
                    <li class="nav-drop-item">
                      <a class="nav-main-link" href="{{ subchild.link }}">{{ subchild.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
</nav>