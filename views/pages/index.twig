{% extends 'layouts/base.twig' %}

{% block content %}

<main class="container-fluid">
  <div class="row mainGrid">
    <button id="desktopMenu" class="hamburger d-none d-lg-block">
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
      <span class="visually-hidden">Menu</span>
    </button>
    <aside id="desktopNav" class="sidebar">
      {% include 'partials/nav.twig' %}
    </aside>

    <div class="col-12 mt-5">
      {% if not fn('is_front_page') %}
        <h1>{{ post.title }}</h1>
      {% endif %}
      {{ post.content }}
      {% if not fn('is_front_page') %}
        {% include 'partials/childCards.twig' %}
      {% endif %}
    </div>
  </div>
</main>

<aside class="tableOfContents">
  <ul id="tableOfContents" class="tableOfContents__list">
  </ul>
</aside>
<button id="tableOfContentsButton" class="tableOfContents__button">Vis innhold</button>
{% endblock %}